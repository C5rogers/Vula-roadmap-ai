{
  "name": "roadmap_ai",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.11",
      "ai": "^6.0.3",
      "@orpc/client": "^1.13.14",
      "@prisma/client": "^7.8.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @roadmap_ai/db db:push",
    "db:studio": "turbo -F @roadmap_ai/db db:studio",
    "db:generate": "turbo -F @roadmap_ai/db db:generate",
    "db:migrate": "turbo -F @roadmap_ai/db db:migrate",
    "db:start": "turbo -F @roadmap_ai/db db:start",
    "db:watch": "turbo -F @roadmap_ai/db db:watch",
    "db:stop": "turbo -F @roadmap_ai/db db:stop",
    "db:down": "turbo -F @roadmap_ai/db db:down"
  },
  "dependencies": {
    "@roadmap_ai/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@roadmap_ai/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "overrides": {
    "@vue/devtools-api": "^8.0.7"
  },
  "packageManager": "bun@1.3.14"
}
